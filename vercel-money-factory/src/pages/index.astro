  <!-- 全球指数分析板块 -->
  <section style="margin-top: 2rem; background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%); padding: 1.5rem; border-radius: 12px; border: 2px solid #4f46e5; box-shadow: 0 2px 10px rgba(79, 70, 229, 0.2);">
    <h2 style="color: #3730a3; font-size: 1.8rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
      <span>🌍</span>
      <span>全球指数分析</span>
      <span style="font-size: 0.8rem; background: #4f46e5; color: #fff; padding: 0.2rem 0.8rem; border-radius: 20px; font-weight: bold;">宏观视野</span>
    </h2>
    <ul style="list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.5rem;">
      <li style="padding: 0.5rem 0; border-bottom: 1px solid #e5e7eb;">
