      </li>
    </ul>
  </section>

  <!-- ETF 分析板块 -->
  <section style="margin-top: 2rem; background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%); padding: 1.5rem; border-radius: 12px; border: 2px solid #db2777; box-shadow: 0 2px 10px rgba(219, 39, 119, 0.2);">
    <h2 style="color: #9f1251; font-size: 1.8rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
      <span>💼</span>
      <span>ETF 分析</span>
      <span style="font-size: 0.8rem; background: #db2777; color: #fff; padding: 0.2rem 0.8rem; border-radius: 20px; font-weight: bold;">核心配置</span>
    </h2>
    <ul style="list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.5rem;">
      <li style="padding: 0.5rem 0; border-bottom: 1px solid #e5e7eb;">
        <a href="https://869.us.ci/etf-analysis/spy-20260331/" style="color: #2563eb; text-decoration: none;">📊 SPY (标普 500 ETF) →</a>
      </li>
      <li style="padding: 0.5rem 0; border-bottom: 1px solid #e5e7eb;">
        <a href="https://869.us.ci/etf-analysis/qqq-20260331/" style="color: #2563eb; text-decoration: none;">🚀 QQQ (纳斯达克 100 ETF) →</a>
      </li>
      <li style="padding: 0.5rem 0; border-bottom: 1px solid #e5e7eb;">
        <a href="https://869.us.ci/etf-analysis/gld-20260331/" style="color: #2563eb; text-decoration: none;">🏆 GLD (黄金 ETF) →</a>
      </li>
      <li style="padding: 0.5rem 0; border-bottom: 1px solid #e5e7eb;">
