    <h2 style="color: #92400e; font-size: 1.8rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
      <span>⚽</span>
      <span>足球比赛预测</span>
      <span style="font-size: 0.8rem; background: #f59e0b; color: #fff; padding: 0.2rem 0.8rem; border-radius: 20px; font-weight: bold;">英超</span>
    </h2>
    {footballPredictions.length > 0 ? (
      <ul style="list-style: none; padding: 0;">
        {footballPredictions.map((prediction) => (
          <li style="padding: 0.75rem 0; border-bottom: 1px solid #e5e7eb;">
            <a href={prediction.url} style="color: #2563eb; text-decoration: none; display: block;">
