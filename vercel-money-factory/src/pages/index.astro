---
import BaseLayout from '../layouts/BaseLayout.astro';

// 获取所有足球预测文章
let footballPredictions = [];
try {
  const predictionFiles = await Astro.glob('./predictions/*.md');
  footballPredictions = predictionFiles.map((post) => ({
    url: `/predictions/${post.file.split('/').pop().replace('.md', '')}`,
    title: post.frontmatter.title,
    homeTeam: post.frontmatter.home_team,
    awayTeam: post.frontmatter.away_team,
    commenceTime: post.frontmatter.commence_time,
  }));
} catch (e) {
  console.log('No predictions found:', e);
}
---

<BaseLayout title="💰 AI 投资智囊 - 全球市场分析与预测专家">
  <!-- 黄金主题头部 -->
  <div style="text-align: center; padding: 2rem 0; background: linear-gradient(135deg, #FFD700 0%, #FFA500 50%, #FFD700 100%); border-radius: 16px; margin-bottom: 2rem; box-shadow: 0 4px 20px rgba(255, 215, 0, 0.4); position: relative; overflow: hidden;">
    <!-- 闪光动画效果 -->
    <div style="position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: linear-gradient(45deg, transparent 30%, rgba(255, 255, 255, 0.3) 50%, transparent 70%); animation: shine 3s infinite;"></div>
    
    <h1 style="font-size: 3rem; font-weight: bold; color: #fff; text-shadow: 2px 2px 8px rgba(0,0,0,0.3); margin-bottom: 0.5rem; position: relative; z-index: 1;">
      🏆 AI 投资智囊 🏆
    </h1>
    <p style="font-size: 1.5rem; color: #fff; text-shadow: 1px 1px 4px rgba(0,0,0,0.3); position: relative; z-index: 1;">
      💎 全球市场分析与预测专家 💎
    </p>
    <p style="font-size: 1.1rem; color: #fff; margin-top: 1rem; opacity: 0.95; position: relative; z-index: 1;">
      AI 驱动的专业级投资决策支持系统 | 实时数据 · 深度分析 · 精准预测
    </p>
  </div>
  
  <!-- 黄金分隔线 -->
  <div style="height: 4px; background: linear-gradient(90deg, transparent, #FFD700, transparent); margin: 2rem 0; border-radius: 2px;"></div>
  
  <!-- 加密货币分析板块 -->
