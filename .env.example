# 示例 .env 文件 - 复制为 .env 并填入你的真实 API Key

# AI 配置（可选其一）
# OpenAI 配置（推荐，更稳定）
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek 配置（需要有效的 API Key）
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://xh.v1api.cc

# 数据源配置
ALPHA_VANTAGE_KEY=demo
FINNHUB_KEY=d6rihfpr01qr194ms4ngd6rihfpr01qr194ms4o0

# 博彩 API 配置（可选）
ODDS_API_KEY=your-odds-api-key-here  # The-Odds-API: 每日 500 次免费额度
SPORTS_API_KEY=your-sports-api-key-here  # API-Football/Basketball

# 变现配置 (逗号分隔多个链接)
# 通用推广链接
AFFILIATE_LINKS=https://your-affiliate-link-1.com,https://your-affiliate-link-2.com

# 币安返佣链接（加密货币专用）
BINANCE_AFFILIATE_LINK=https://www.binance.com/activity/referral-entry/CPA?ref=CPA_007OA94MQ0
