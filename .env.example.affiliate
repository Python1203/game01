# 淘宝联盟 & 京东联盟配置
# 复制此文件为 .env.local 并填入你的真实配置

# ===========================================
# 淘宝联盟配置
# 获取方式：登录阿里妈妈 → 推广管理 → 创建推广位
# ===========================================
# PID 格式：mm_会员 ID_站点 ID_推广位 ID
NEXT_PUBLIC_TAOBAO_PID=mm_xxxxxxxxx_xxxxxxxxx_xxxxxxxxxx

# 联盟 ID（可选，用于生成 CPC 链接）
NEXT_PUBLIC_TAOBAO_UNION_ID=xxxxxx

# ===========================================
# 京东联盟配置
# 获取方式：登录京东联盟 → 我的联盟 → 推广管理
# ===========================================
# PID 格式：站点 ID_推广位 ID
NEXT_PUBLIC_JD_PID=xxxxxxxxxx_xxxxxxxxxx

# 联盟 ID（用于生成 CPC 和短链）
NEXT_PUBLIC_JD_UNION_ID=xxxxxx

# ===========================================
# 其他配置（可选）
# ===========================================
# 返利比例（用于计算返现金额，0.5 = 50%）
NEXT_PUBLIC_COMMISSION_RATE=0.5

# 客服联系方式（用于用户领取返现）
NEXT_PUBLIC_CUSTOMER_SERVICE_WECHAT=your_wechat_id
